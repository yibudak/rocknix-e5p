 static void dw_mipi_dsi_dphy_interface_config(struct dw_mipi_dsi *dsi)
@@ -1022,12 +1029,46 @@
 		phy_ops->power_on(dsi->plat_data->priv_data);
 }
 
+/*
+ * RK356x quirk (GameMT E5 Plus port): the vendor BSP holds the VOP2 video
+ * port in standby while the DSI link is configured and switched to video
+ * mode, then releases it, so the controller locks to a fresh frame. Without
+ * this the first frame is captured mid-stream and the image is displayed
+ * with a constant vertical offset of vsa+vbp lines (wrap-around).
+ * Standby takes effect at the end of the current frame.
+ */
+static void dw_mipi_dsi_vop2_standby(bool on)
+{
+	void __iomem *regs;
+	u32 val;
+
+	if (!IS_ENABLED(CONFIG_ARCH_ROCKCHIP))
+		return;
+
+	regs = ioremap(0xfe040000, 0x1000);
+	if (!regs)
+		return;
+	val = readl(regs + 0xc00);	/* VP0_DSP_CTRL */
+	if (on)
+		val |= BIT(31);		/* standby */
+	else
+		val &= ~BIT(31);
+	writel(val, regs + 0xc00);
+	writel(0x8001, regs);	/* E5P: VP0 cfg_done + glb_en - standby bit is shadowed */
+	pr_info("E5P vop2_standby(%d): dsp_ctrl=0x%08x\n", on, readl(regs + 0xc00));
+	iounmap(regs);
+	if (on)
+		msleep(40);		/* let standby latch at frame end */
+}
+
 static void dw_mipi_dsi_bridge_atomic_pre_enable(struct drm_bridge *bridge,
 						 struct drm_atomic_state *state)
 {
 	struct dw_mipi_dsi *dsi = bridge_to_dsi(bridge);
 
 	/* Power up the dsi ctl into a command mode */
+	dw_mipi_dsi_vop2_standby(true);
+
 	dw_mipi_dsi_mode_set(dsi, &dsi->mode);
 	if (dsi->slave)
 		dw_mipi_dsi_mode_set(dsi->slave, &dsi->mode);
@@ -1050,6 +1091,8 @@
 
 	/* Switch to video mode for panel-bridge enable & panel enable */
 	dw_mipi_dsi_set_mode(dsi, MIPI_DSI_MODE_VIDEO);
+
+	dw_mipi_dsi_vop2_standby(false);
 	if (dsi->slave)
 		dw_mipi_dsi_set_mode(dsi->slave, MIPI_DSI_MODE_VIDEO);
 }
